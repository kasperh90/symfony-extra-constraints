{
  "name": "kasperh90/symfony-extra-constraints",
  "type": "library",
  "description": "A collection of additional validation constraints for the Symfony Validator component",
  "keywords": [
    "symfony",
    "validator",
    "validation",
    "constraints",
    "symfony-validator"
  ],
  "homepage": "https://github.com/kasperh90/symfony-extra-constraints",
  "license": "MIT",
  "authors": [
    {
      "name": "Kasper Hansen",
      "email": "kasper.h90@gmail.com"
    }
  ],
  "require": {
    "php": ">=8.2",
    "symfony/validator": "^7.4|^8.0"
  },
  "autoload": {
    "psr-4": {
      "Kasperh90\\SymfonyExtraConstraints\\": "src/"
    },
    "exclude-from-classmap": [
      "/tests/"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Kasperh90\\SymfonyExtraConstraints\\Tests\\": "tests/"
    }
  }
}
